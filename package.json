{
  "name": "net-tools-hub",
  "version": "0.3.0",
  "description": "🛠️ A field manual of 210 actively-maintained open-source network tools (proxies, VPNs, Clash family, GitHub acceleration, DNS, security, monitoring). Static site, MIT, multilingual EN/中文/日本語.",
  "author": {
    "name": "badhope",
    "url": "https://github.com/badhope"
  },
  "license": "MIT",
  "private": false,
  "keywords": [
    "nettools",
    "nettools-hub",
    "network-tools",
    "proxy",
    "vpn",
    "clash",
    "shadowsocks",
    "v2ray",
    "sing-box",
    "hysteria",
    "trojan",
    "github-acceleration",
    "dns",
    "subscription",
    "navigation",
    "directory",
    "catalog",
    "open-source",
    "static-site",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "github-pages",
    "i18n",
    "multilingual",
    "english",
    "chinese",
    "japanese"
  ],
  "homepage": "https://badhope.github.io/NetTools-Hub",
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/NetTools-Hub.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/NetTools-Hub/issues"
  },
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "start": "npx serve@latest out -p 8080",
    "lint": "eslint",
    "validate": "node scripts/validate-projects.mjs",
    "refresh": "node scripts/refresh-projects.mjs",
    "scan": "node scripts/scan-awesome.mjs",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "node scripts/analyze-bundle.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.57.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
